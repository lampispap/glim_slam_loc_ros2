<?xml version="1.0" encoding="utf-8"?>

<robot
  name="amr_tvc">
  <link name="base_footprint"/>
  <link name="base_link"/>
  <link name="velodyne"/>
  <link name="imu_link"/>
  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0.0 0.0 0.0" rpy="0 0 0"/>
  </joint>
  <joint name="lidar" type="fixed">
    <origin
      xyz="0.0 0.0 0.0"
      rpy="0 0 0.0" />
    <parent
      link="base_link" />
    <child
      link="velodyne" />
    <axis
      xyz="0 0 0" />
  </joint>
  <joint name="imu_joint" type="fixed">
    <parent link="velodyne"/>
    <child link="imu_link"/>
    <origin xyz="0.0 0.0 0.0" rpy="0.0 3.1415927 0.0"/>
  </joint>
</robot>
