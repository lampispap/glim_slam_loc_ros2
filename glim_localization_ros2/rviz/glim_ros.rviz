    - Class: rviz_default_plugins/TF
      Enabled: true
      Frame Timeout: 15
      Frames:
        All Enabled: true
        base_footprint:
          Value: true
        base_link:
          Value: true
        gps:
          Value: true
        imu:
          Value: true
        map:
          Value: true
        odom:
          Value: true
        utm:
          Value: true
        velodyne:
          Value: true
      Marker Scale: 100
      Name: TF
      Show Arrows: true
      Show Axes: true
      Show Names: true
      Tree:
        utm:
          map:
            odom:
              base_footprint:
                base_link:
                  velodyne:
                    gps:
                      {}
                    imu:
                      {}
