{
  /*** SubMapping ***
  // See config_sub_mapping_gpu.json for the full description of the parameters.
  */
  "sub_mapping": {
    "so_name": "libsub_mapping.so",
    "enable_imu": true,
    "enable_optimization": true,
    // Keyframe update strategy
    "max_num_keyframes": 10,
    "keyframe_update_strategy": "DISPLACEMENT",
    "keyframe_update_min_points": 500,
    "keyframe_update_interval_rot": 3.14,
    "keyframe_update_interval_trans": 1.0,
    "keyframe_update_interval_time": 5.0,
    "max_keyframe_overlap": 0.6,
    // Relative pose factors
    "create_between_factors": true,
    "between_registration_type": "GICP",
    // Registration error factors
    "registration_error_factor_type": "VGICP",
    "keyframe_randomsampling_rate": 1.0,
    "keyframe_voxel_resolution": 0.15, // NOTE: previous_value : 0.25
    "keyframe_voxelmap_levels": 2,
    "keyframe_voxelmap_scaling_factor": 2.0,
    // Post processing
    "submap_downsample_resolution": 0.2,
    // "submap_downsample_resolution": 0.25,
    // "submap_voxel_resolution": 0.25
    "submap_voxel_resolution": 0.15, // NOTE: previous_value : 0.5
    "enable_gps": false,
    "gps_horizontal_weight": 1e4,
    "gps_vertical_weight": 1e-10, // ignore if weight is too small
    "gps_max_hdop": 2.0,
    "gps_max_distance": 3.0
  }
}